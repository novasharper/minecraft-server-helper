FROM fedora:43

RUN dnf install -y \
    python3-pydantic \
    python3-pyyaml \
    python3-requests \
    python3-tqdm \
    python3-pytest \
    python3-pip \
    java-21-openjdk-headless \
    && dnf clean all

WORKDIR /app
COPY pyproject.toml ./
COPY src/ ./src/

# Install the mc-helper entry point without reinstalling RPM-managed deps
RUN pip3 install --no-deps -e .

COPY tests/e2e/ ./tests/e2e/

CMD ["pytest", "tests/e2e/test_e2e.py", "-v", "--tb=short"]
