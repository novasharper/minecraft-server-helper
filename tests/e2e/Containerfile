FROM fedora:43

RUN dnf install -y \
        python3-pydantic \
        python3-pyyaml \
        python3-requests \
        python3-tqdm \
        java-21-openjdk-headless \
 && dnf clean all \
 && useradd --create-home mchelper

COPY cli-shim.py /usr/local/bin/mc-helper
RUN chmod +x /usr/local/bin/mc-helper

USER mchelper
WORKDIR /app
